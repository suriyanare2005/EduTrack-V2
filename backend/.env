# EduTrack Backend Environment Variables Example
# Duplicate this file as '.env' and fill in your details.

# Database URL (Defaults to SQLite in local development, set PostgreSQL URL in production)
DATABASE_URL=sqlite:///./edutrack.db

# JWT Configuration
JWT_SECRET=129cd9cb-6f7c-4c69-973b-121ad79f8f27
JWT_EXPIRY_MINUTES=1440

# Google Gemini API (For AI Loan Advisor Chatbot summaries)
GEMINI_API_KEY=AQ.Ab8RN6KGpm9AVt4jtAPRLrYg2iMWRM-8I7XJI7faV-5bYt20yw

# Google OAuth Credentials (For Google Sign-In backend verification)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP Mail Server Configuration (For Forgot/Reset Password flow)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
SMTP_FROM=noreply@edutrack.com
